{
  "name": "vite-patcher",
  "version": "0.0.3",
  "description": "Inject automatically Vite Plugins and code into vite.config",
  "type": "module",
  "keywords": [
    "vite",
    "patch",
    "patches",
    "pwa"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/vite-patcher.git"
  },
  "bugs": {
    "url": "https://github.com/node-ecosystem/vite-patcher/issues"
  },
  "bin": "./dist/bin/vite-patcher.mjs",
  "scripts": {
    "build": "tsdown",
    "test": "yarn node --test test/*.test.js",
    "pwa": "yarn node ./src/bin/vite-patcher.mjs pwa",
    "od": "yarn outdated"
  },
  "dependencies": {
    "magicast": "^0.5.2"
  },
  "devDependencies": {
    "@yarnpkg/sdks": "^3.2.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "vite": "*"
  },
  "files": [
    "dist"
  ],
  "packageManager": "yarn@4.14.1"
}
