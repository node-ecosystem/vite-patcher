{
  "name": "vite-patcher",
  "version": "0.0.5",
  "description": "Inject automatically Vite Plugins and code into vite.config",
  "type": "module",
  "keywords": [
    "vite",
    "patch",
    "patches",
    "pwa"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/vite-patcher.git"
  },
  "bugs": {
    "url": "https://github.com/node-ecosystem/vite-patcher/issues"
  },
  "bin": "./dist/bin/vite-patcher.mjs",
  "scripts": {
    "build": "tsdown",
    "test": "yarn node --test test/*.test.ts",
    "pwa": "yarn node ./src/bin/vite-patcher.ts pwa",
    "lint": "eslint src/**/*.ts",
    "od": "yarn outdated"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@yarnpkg/sdks": "^3.2.3",
    "eslint": "^10.2.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vike": "^0.4.258",
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "vike": "*",
    "vite": "*"
  },
  "peerDependenciesMeta": {
    "vike": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "yarn@4.14.1"
}
